---
interface Props {
  images: { src: string; alt?: string }[];
  columns?: 2 | 3;
}

const { images, columns = 3 } = Astro.props;
---

<div class={`gallery gallery-${columns}`}>
  {images.map((img) => (
    <a href={img.src} class="gallery-item" target="_blank">
      <img src={img.src} alt={img.alt || ''} loading="lazy" />
    </a>
  ))}
</div>

<style>
  .gallery {
    display: grid;
    gap: 0.75rem;
    margin: 1rem 0;
  }

  .gallery-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .gallery-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .gallery-item {
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
    display: block;
  }

  .gallery-item:hover img {
    transform: scale(1.05);
  }

  @media (max-width: 600px) {
    .gallery-3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
