---
import ProjectLayout from '../layouts/ProjectLayout.astro';
import YouTube from '../components/YouTube.astro';
import Gallery from '../components/Gallery.astro';

const images = [
  { src: '/images/unity/2d-games-box-01.jpg' },
  { src: '/images/unity/2d-games-box-02.jpg' },
];
---

<ProjectLayout title="2D Games Box">
  <YouTube id="8INv6UMpktg" />

  <h2>Screenshots</h2>
  <Gallery images={images} columns={2} />

  <h2>Project description</h2>
  <ul>
    <li>Devices: Mobile</li>
    <li>Platforms: Android, IOS</li>
    <li>Game Engine: Unity</li>
    <li>Game Genres: Casual, 2D</li>
    <li>Languages: C#</li>
  </ul>
  <p>2D Games Box is a games collection that contains a lot of mini casual games, available on Android and IOS, made with Unity</p>
  <ul>
    <li>Store link: <a href="https://apkpure.com/2d-games-box/com.nullpointer.gamesbox1" target="_blank" rel="noopener noreferrer">https://apkpure.com/2d-games-box/com.nullpointer.gamesbox1</a></li>
  </ul>
</ProjectLayout>
