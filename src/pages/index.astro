<style>
  .home-layout {
    display: grid;
    grid-template-columns: 1fr 250px;
    gap: 2rem;
  }

  .home-content {
    min-width: 0;
  }

  section {
    margin-bottom: 2rem;
  }

  .year-group {
    margin-bottom: 2rem;
  }

  .year-heading {
    font-size: 1.25rem;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.4rem;
    margin-bottom: 1rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .author-sidebar {
    position: relative;
  }

  .author-card {
    position: sticky;
    top: 5rem;
    text-align: center;
    padding: 1.5rem 1rem;
    background: var(--bg-secondary);
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  .author-avatar {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 0.75rem;
  }

  .author-card h3 {
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .author-bio {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
  }

  .author-location {
    font-size: 0.8rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
  }

  .author-links {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
  }

  .author-links a {
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .author-links a:hover {
    color: var(--accent);
  }

  @media (max-width: 1024px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .home-layout {
      grid-template-columns: 1fr;
    }

    .author-sidebar {
      order: -1;
    }

    .author-card {
      position: static;
    }
  }

  @media (max-width: 500px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
