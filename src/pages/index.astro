---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const allProjects = await getCollection("projects");

// Group by year, sorted newest first
const projectsByYear = new Map<number, typeof allProjects>();
for (const project of allProjects) {
  const year = project.data.year;
  if (!projectsByYear.has(year)) {
    projectsByYear.set(year, []);
  }
  projectsByYear.get(year)!.push(project);
}
const sortedYears = [...projectsByYear.keys()].sort((a, b) => b - a);
---

<BaseLayout title="Home">
  <div class="home-layout">
    <div class="home-content">
      <section>
        <h1>About Me</h1>
        <hr />
        <p>
          Senior Game Developer, 10+ years of experience with Unity and Unreal
          Engine. Shipped games across PC, mobile, and VR. Built UE plugins used
          in production by external studios. Creator of the open-source Async
          Loading Screen plugin (Epic MegaGrant 2022, UE Community Spotlight).
          Also experienced in the 3D digital content creation pipeline.
        </p>
      </section>

      <section>
        <h1>My Projects</h1>
        <hr />
        {
          sortedYears.map((year) => (
            <div class="year-group">
              <h2 class="year-heading">{year}</h2>
              <div class="projects-grid">
                {projectsByYear.get(year)!.map((project) => (
                  <ProjectCard
                    title={project.data.title}
                    excerpt={project.data.excerpt}
                    image={project.data.image}
                    url={`/${project.data.slug}`}
                  />
                ))}
              </div>
            </div>
          ))
        }
      </section>

      <p>Feel free to contact me if you have any questions/remarks!</p>
      <p>Best Regards,<br />Truong Bui</p>
    </div>

    <aside class="author-sidebar">
      <div class="author-card">
        <img
          src="/images/truong-bui.jpg"
          alt="Truong Bui"
          class="author-avatar"
        />
        <h3>Truong Bui</h3>
        <p class="author-bio">Senior Game Developer</p>
        <p class="author-location">
